@import "tailwindcss";

@theme {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  
  --font-sans: var(--font-inter);
  --font-heading: var(--font-space-grotesk);

  --radius-lg: var(--radius);
  --radius-md: calc(var(--radius) - 2px);
  --radius-sm: calc(var(--radius) - 4px);
}

:root {
  /* Default to dark mode for the futuristic theme */
  --background: hsl(0, 0%, 3%);
  --foreground: hsl(0, 0%, 98%);

  --primary: hsl(190, 90%, 50%); /* Cyan */
  --primary-foreground: hsl(0, 0%, 9%);

  --secondary: hsl(280, 80%, 60%); /* Purple */
  --secondary-foreground: hsl(0, 0%, 98%);

  --accent: hsl(190, 90%, 50%);
  --accent-foreground: hsl(0, 0%, 9%);

  --muted: hsl(0, 0%, 15%);
  --muted-foreground: hsl(0, 0%, 60%);

  --radius: 0.5rem;
}

@layer base {
  * {
    border-color: var(--muted);
  }
  body {
    background-color: var(--background);
    color: var(--foreground);
    font-family: var(--font-sans), sans-serif;
    overflow-x: hidden;
  }
  
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading), sans-serif;
  }
}

/* Custom Scrollbar */
::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: var(--background); 
}
::-webkit-scrollbar-thumb {
  background: var(--muted); 
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--primary); 
}

/* Utilities for glassmorphism and glows */
@utility glass {
  background: rgba(255, 255, 255, 0.03);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

@utility text-glow {
  text-shadow: 0 0 20px color-mix(in srgb, var(--primary) 50%, transparent);
}

@utility box-glow {
  box-shadow: 0 0 30px color-mix(in srgb, var(--primary) 20%, transparent);
}
